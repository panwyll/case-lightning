{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/v1/graph/subscriptions/renew",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/referrals/apply",
      "schedule": "0 4 1 * *"
    },
    {
      "path": "/api/v1/onboarding/resume",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/v1/cron/send-scheduled",
      "schedule": "*/5 * * * *"
    }
  ]
}
