# ── Marketing site (existing) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
NEXT_PUBLIC_GA_ID=

# ── Product backend ──────────────────────────────────────────────────────────
# App origin (Vercel domain in prod; https://localhost:3000 for local sideload)
APP_URL=https://localhost:3000

# Postgres (Supabase pooler / direct connection string). Needed for all product
# features and for `npm run migrate`. Enable the `vector` + `pgcrypto` extensions.
DATABASE_URL=

# Session cookie signing + at-rest encryption of per-user BYOK keys (long random)
SESSION_JWT_SECRET=
APP_ENCRYPTION_KEY=

# Microsoft Entra (Azure AD) app registration — single tenant recommended.
# Redirect URI: ${APP_URL}/api/v1/auth/callback
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://localhost:3000/api/v1/auth/callback
GRAPH_SCOPES=User.Read Mail.Read Mail.ReadWrite Files.ReadWrite Sites.ReadWrite.All Team.ReadBasic.All ChannelMessage.Send

# AI — Claude for generation
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Embeddings (optional — RAG degrades gracefully without it). voyage | openai
EMBEDDINGS_PROVIDER=voyage
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large
EMBEDDING_DIM=1024
# OPENAI_API_KEY=        # only if EMBEDDINGS_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# OneDrive root folder for per-case knowledge bases
ONEDRIVE_ROOT=CaseLightning

# Protects the subscription-renewal + referral-apply crons (Vercel Cron sends it as a Bearer token).
# Auto-triage subscriptions need a public HTTPS APP_URL — they don't work on localhost.
CRON_SECRET=

# ── Billing + referrals (Stripe) ─────────────────────────────────────────────
# The existing NEXT_PUBLIC_STRIPE_PAYMENT_LINK drives /start-trial. These power
# the webhook-driven referral commission ledger (£50/mo account credit per referral).
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/v1/billing/webhook (Stripe Dashboard → Webhooks).
# Subscribe to: checkout.session.completed, invoice.paid, invoice.payment_failed,
# invoice.voided, charge.refunded, customer.subscription.{created,updated,deleted}.
STRIPE_WEBHOOK_SECRET=
REFERRAL_COMMISSION_PENNIES=5000
BILLING_CURRENCY=gbp

# Optional: restrict draft recipients to these domains (comma separated)
ALLOWED_EXTERNAL_DOMAINS=
